FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      blockMeshDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

scale res;

vertices
(
    (0 0 0)
    (dx 0 0)
    (dx dy 0)
    (0 dy 0)
    (0 0 dz)
    (dx 0 dz)
    (dx dy dz)
    (0 dy dz)
);

blocks
(
    hex (0 1 2 3 4 5 6 7) (nx ny nz) simpleGrading (1 1 1)
);

edges
(
);

boundary
(
    walls
    {
        type wall;
        faces
        (
            (0 1 5 4)
            (3 7 6 2)
        );
    }

    // The +x and -x patches are intentionally given temporary names
    // (`inletSrc` / `outletSrc`) and declared as plain `patch` so that
    // snappyHexMesh doesn't try to enforce any cyclic match during snap.
    //
    // After snappy, system/createPatchDict consumes these source patches
    // and emits two new patches called `inlet` and `outlet` of type
    // `cyclic`.  The buffered STL gives identical full-cross-section open
    // patches on both ends, so plain cyclic matches without AMI.
    //
    // The renames `inlet` -> `inletSrc` (and similarly for outlet) are
    // necessary because v2212's createPatch silently no-ops if the
    // source patch name collides with the target patch name.

    inletSrc
    {
        type patch;
        faces
        (
            (0 4 7 3)
        );
    }

    outletSrc
    {
        type patch;
        faces
        (
            (1 2 6 5)
        );
    }

    frontandback
    {
        type empty;
        faces
        (
            (0 3 2 1)
            (4 5 6 7)
        );
    }
);


