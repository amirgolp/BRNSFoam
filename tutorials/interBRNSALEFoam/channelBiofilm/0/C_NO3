FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    object      C_NO3;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 -3 0 0 1 0 0];

internalField   uniform 0.5;   // 0.5 mol/m³ initial nitrate

boundaryField
{
    inlet
    {
        type            fixedValue;
        value           uniform 0.5;
    }

    outlet
    {
        type            zeroGradient;
    }

    top
    {
        type            zeroGradient;
    }

    biofilmWall
    {
        type            zeroGradient;
    }

    frontAndBack
    {
        type            empty;
    }
}

