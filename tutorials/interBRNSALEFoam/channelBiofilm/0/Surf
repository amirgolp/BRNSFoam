FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    object      Surf;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 -2 0 0 1 0 0];

internalField   uniform 0;

boundaryField
{
    inlet
    {
        type            zeroGradient;
    }

    outlet
    {
        type            zeroGradient;
    }

    top
    {
        type            zeroGradient;
    }

    biofilmWall
    {
        type            reactingWall;
        surfaceMasters
        {
        }
        value           uniform 0;
    }

    frontAndBack
    {
        type            empty;
    }
}

