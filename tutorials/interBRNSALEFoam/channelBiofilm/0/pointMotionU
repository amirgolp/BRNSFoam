FoamFile
{
    version     2.0;
    format      ascii;
    class       pointVectorField;
    location    "0";
    object      pointMotionU;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 1 -1 0 0 0 0];

internalField   uniform (0 0 0);

boundaryField
{
    inlet
    {
        type            fixedValue;
        value           uniform (0 0 0);
    }

    outlet
    {
        type            fixedValue;
        value           uniform (0 0 0);
    }

    top
    {
        type            fixedValue;
        value           uniform (0 0 0);
    }

    biofilmWall
    {
        // Solid growth velocity BC (biofilm, precipitation, or dissolution)
        type            solidGrowthVelocity;
        speciesName     X_A;
        UName           U;
        growthCoeff     1e-5;
        rhoSolid        1100;
        Mw              1.0;
        tauCrit         1.0;
        kDetach         1e-7;
        detachExponent  1.0;
        mu              1e-3;
        maxVelocity     1e-6;
        value           uniform (0 0 0);
    }

    frontAndBack
    {
        type            empty;
    }
}

