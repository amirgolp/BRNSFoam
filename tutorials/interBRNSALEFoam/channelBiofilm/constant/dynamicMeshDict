// Dynamic mesh for biofilm growth
dynamicFvMesh   dynamicMotionSolverFvMesh;

motionSolverLibs (fvMotionSolvers);

motionSolver    velocityLaplacian;

// Diffusivity controls how mesh motion propagates from moving boundary
diffusivity     quadratic inverseDistance (biofilmWall);

