// Single-phase form expected by darcyBrinkmanBRNSFoam:
//   solutionSpecies: list of solute fields read from 0/<name>
//   D_<name>:        per-species diffusivity (must match each entry above)

solutionSpecies ( O2 );

D_O2    D_O2 [ 0 2 -1 0 0 0 0 ] 2.1e-9;

