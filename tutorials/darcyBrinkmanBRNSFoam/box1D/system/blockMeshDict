FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      blockMeshDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

// Quasi-1D porous column: 10mm long x 1mm tall x 0.1mm deep (empty in z).
scale   1e-3;

vertices
(
    (0  0  0)
    (10 0  0)
    (10 1  0)
    (0  1  0)
    (0  0  0.1)
    (10 0  0.1)
    (10 1  0.1)
    (0  1  0.1)
);

blocks
(
    hex (0 1 2 3 4 5 6 7) (100 10 1) simpleGrading (1 1 1)
);

edges ();

boundary
(
    inlet
    {
        type patch;
        faces ( (0 4 7 3) );
    }
    outlet
    {
        type patch;
        faces ( (1 2 6 5) );
    }
    walls
    {
        type wall;
        faces
        (
            (0 1 5 4)   // bottom
            (3 7 6 2)   // top
        );
    }
    frontAndBack
    {
        type empty;
        faces
        (
            (0 3 2 1)
            (4 5 6 7)
        );
    }
);

