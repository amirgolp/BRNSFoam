FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "system";
    object      setFieldsDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

defaultFieldValues
(
    volScalarFieldValue alpha.water 0
);

regions
(
    // Water in bottom 60% of channel (0-3mm of 5mm total)
    boxToCell
    {
        box (0 0 0) (0.01 0.003 0.0001);
        fieldValues
        (
            volScalarFieldValue alpha.water 1
        );
    }
);

