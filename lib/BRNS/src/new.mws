11 "" 1 "" {XPPMATH 20 ">I+listsolidsG6\"7\"" }}}}}{SECT 0 {PARA 3 "" 
0 "" {TEXT 321 28 " Biogeochemistry - Rate laws" }}{PARA 0 "" 0 "" 
{TEXT 318 14 "Definition of " }{TEXT 276 17 "kinetic rate laws" }}
{PARA 0 "" 0 "" {TEXT 26 8 "rate.i :" }{TEXT 318 18 " array of rates. \+
\n" }{TEXT 277 76 "- For equilibrium rate expression, a kinetic rate M
UST be specified as well." }{TEXT 318 297 " It will be overwritten in \+
the equilibrium section below, but you need it as space holder and sto
ichiometry. Furthermore, the steadystate module uses detailed balancin
g method with fast kinetics. Therefore, in the example below, kf will \+
have to be defined as a rather large number and kb = kf*Keq\n" }{TEXT 
318 70 "note: all other variables are temporary and are NOT parsed to \+
the ACG\n" }{TEXT 318 2 "- " }{TEXT 278 22 "conditional statements" }
{TEXT 318 454 ": if a rate law depends on a conditional statement you \+
need to make use of the subroutine switches.f. Example: dissolution (R
d) is only to take place at undersaturation, thus  Rd= f(saturation). \+
If saturation > 1, Rd>0, else Rd=0. This canbe implemented as Rd:=k*H1
*saturation, where H1 is toggled between 0 and 1. Rather than giving t
he condition here in maple, for now you need to do this in \"switches.
f\", where you program the conditions for H1, e.g. " }{TEXT 279 31 "H1
=0, If (A*B/K>1) then H1 = 1." }{TEXT 318 1 "\n" }{TEXT 318 2 " \n" }
{TEXT 280 10 "example: \n" }{TEXT 281 61 "rate1 := 1000.*O2*hs; # rate
 law for 2O2 + HS -> SO4 + Hplus\n" }{TEXT 282 88 "rate2 := kf*hplus*c
o3 - kb*hco3; # kinetic rate law for HCO3 = CO3 + Hplus (equilibrium)"
 }}{SECT 0 {PARA 4 "" 0 "" {TEXT 323 0 "" }}{EXCHG {PARA 4 "" 0 "" 
{TEXT 323 25 " Primary redox reactions " }{HYPERLNK 17 "WWW" 4 "http:/
/www.geo.uu.nl/Research/Geochemistry/kb/Knowledgebook/Hetero3.pdf" "" 
}{TEXT 323 0 "" }{MPLTEXT 1 0 0 "" }}}{PARA 4 "" 0 "" {TEXT 323 31 " S
ulfide Re-oxidation reactions" }}{EXCHG {PARA 0 "> " 0 "" {MPLTEXT 1 
0 53 "rate1 := C_doc/(kA+C_doc)*O2/(kB+O2)*miu_max*C_bio ;\n" }
{MPLTEXT 1 0 24 "rate2 := -k_dec*C_bio ;\n" }}{PARA 11 "" 1 "" 
{XPPMATH 20 ">I&rate1G6\"*.I&C_docGF$\"\"\",&I#kAGF$F'F&F'!\"\"I#O2GF$
F',&I#kBGF$F'F+F'F*I(miu_maxGF$F'I&C_bioGF$F'" }}{PARA 11 "" 1 "" 
{XPPMATH 20 ">I&rate2G6\",$*&I&k_decGF$\"\"\"I&C_bioGF$F(!\"\"" }}}}}
{SECT 0 {PARA 3 "" 0 "" {TEXT 321 33 " Biogeochemistry - Stoichiometry
\n" }}{PARA 0 "" 0 "" {TEXT 318 46 "Stoichiometry of the biogeochemica
l reactions\n" }{TEXT 26 9 "d.sp.dt :" }{TEXT 318 66 " rates of change
 of sp due to the sum of biogeochemical reactions\n" }{TEXT 318 44 "no
te that rateX must be referred to as rX  \n" }{TEXT 318 2 " \n" }{TEXT
 283 9 "example:\n" }{TEXT 284 16 "dO2dt := -2*r1;\n" }{TEXT 285 14 "d
hco3dt = -r2;" }{TEXT 318 1 " " }}{EXCHG {PARA 0 "> " 0 "" {MPLTEXT 1 
0 22 "delstd := 0.0112372 ;\n" }{MPLTEXT 1 0 16 "s_dens := 2.5 ;\n" }
{MPLTEXT 1 0 48 "#SD := 1.0e3 * s_dens * (1.0 - por(j)) / por(j);" }
{MPLTEXT 1 0 0 "" }}{PARA 11 "" 1 "" {XPPMATH 20 ">I'delstdG6\"$\"'sB6
!\"(" }}{PARA 11 "" 1 "" {XPPMATH 20 ">I's_densG6\"$\"#D!\"\"" }}}
{PARA 0 "" 0 "" {TEXT 318 0 "" }}{EXCHG {PARA 0 "> " 0 "" {MPLTEXT 1 
0 26 "dC_docdt := 0.001; #-r1 / " }{MPLTEXT 1 0 6 "yields" }{MPLTEXT 
1 0 16 " ;#+ 0.5 * r2 ;\n" }{MPLTEXT 1 0 54 "dO2dt := -r2; #-r1 *(1.0 \+
-yields)/yields ; #-1 * (1 - " }{MPLTEXT 1 0 6 "yields" }{MPLTEXT 1 0 
9 ") * r1 ;\n" }{MPLTEXT 1 0 15 "dhco3dt := 0; #" }{MPLTEXT 1 0 12 "r1
 * (1.0 - " }{MPLTEXT 1 0 6 "yields" }{MPLTEXT 1 0 1 " " }{MPLTEXT 1 
0 12 ")/yields  ;\n" }{MPLTEXT 1 0 12 "dhplusdt := " }{MPLTEXT 1 0 4 "
0; #" }{MPLTEXT 1 0 13 "r1 * ( 1.0 - " }{MPLTEXT 1 0 6 "yields" }
{MPLTEXT 1 0 10 " )/yields " }{MPLTEXT 1 0 2 " ;" }{MPLTEXT 1 0 1 "\n"
 }{MPLTEXT 1 0 10 "dnh4dt := " }{MPLTEXT 1 0 4 "0; #" }{MPLTEXT 1 0 1 
"-" }{MPLTEXT 1 0 13 "r1 * ( 1.0 - " }{MPLTEXT 1 0 6 "yields" }
{MPLTEXT 1 0 9 " )/yields" }{MPLTEXT 1 0 2 " ;" }{MPLTEXT 1 0 1 "\n" }
{MPLTEXT 1 0 12 "dC_socdt := " }{MPLTEXT 1 0 4 "0; #" }{MPLTEXT 1 0 
12 "- 0.5 * r2 ;" }{MPLTEXT 1 0 1 "\n" }{MPLTEXT 1 0 12 "dC_biodt := "
 }{MPLTEXT 1 0 4 "0; #" }{MPLTEXT 1 0 9 "r1 + r2 ;" }}{PARA 11 "" 1 ""
 {XPPMATH 20 ">I)dC_docdtG6\",$I#r1GF$!\"\"" }}{PARA 11 "" 1 "" 
{XPPMATH 20 ">I&dO2dtG6\",$I#r2GF$!\"\"" }}{PARA 11 "" 1 "" {XPPMATH 
20 ">I(dhco3dtG6\"\"\"!" }}{PARA 11 "" 1 "" {XPPMATH 20 ">I)dhplusdtG6
\"\"\"!" }}{PARA 11 "" 1 "" {XPPMATH 20 ">I'dnh4dtG6\"\"\"!" }}{PARA 
11 "" 1 "" {XPPMATH 20 ">I)dC_socdtG6\"\"\"!" }}{PARA 11 "" 1 "" 
{XPPMATH 20 ">I)dC_biodtG6\"\"\"!" }}}}{SECT 0 {PARA 3 "" 0 "" {TEXT 
321 29 " Biogeochemistry - Equilibria" }}{PARA 0 "" 0 "" {TEXT 318 41 
"Specification of equilibrium constraints\n" }{TEXT 26 10 "eqrxnsId :"
 }{TEXT 318 75 " set of kinetic reactions which are overuled by a ther
modynamic constraint " }}{PARA 0 "" 0 "" {TEXT 26 20 "equilibriumseqns
[i] " }{TEXT 318 42 ": Equilibrium constraint for reaction i  \n" }
{TEXT 318 1 "\n" }{TEXT 286 9 "example:\n" }{TEXT 287 20 "eqrxnID := [
r2,rX];\n" }{TEXT 288 44 "equilibriumeqns[1] := hplus*co3 - Keq*hco3;
\n" }{TEXT 289 26 "equilibriumeqns[2] := ...;" }}{EXCHG {PARA 0 "> " 0
 "" {MPLTEXT 1 0 15 "eqrxnId := [] ;" }}{PARA 11 "" 1 "" {XPPMATH 20 "
>I(eqrxnIdG6\"7\"" }}}{EXCHG {PARA 0 "> " 0 "" {MPLTEXT 1 0 33 "#equil
ibriumeqns[1] := b - k3*c ;" }}}}{SECT 0 {PARA 3 "" 0 "" {TEXT 321 29 
" Biogeochemistry - Parameters" }}{PARA 0 "" 0 "" {TEXT 32 41 "Values \+
of rates constants and parameters " }{TEXT 318 1 "\n" }{TEXT 318 82 "I
n this section, all parameters defined in section 'Rate laws' should b
e defined.\n" }{TEXT 26 6 "nparam" }{TEXT 318 34 ": number of paramete
rs to define \n" }{TEXT 318 21 "The list is given by " }{TEXT 26 8 "bi
o_name" }{TEXT 318 26 "; the values collected in " }{TEXT 26 8 "bio_va
l." }{TEXT 318 1 "\n" }{TEXT 318 60 "note that for double precision, 1
0 should be written as 10.\n" }{TEXT 318 1 "\n" }{TEXT 290 9 "example:
\n" }{TEXT 291 11 "nparam:=4;\n" }{TEXT 292 30 "bio_name:=[kmo2hs,kf,k
b,Keq];\n" }{TEXT 293 18 "vkf :=1.0*10^(5);\n" }{TEXT 294 22 "vKeq:=1.
0*10^(-10.4);\n" }{TEXT 295 16 "vkb :=vkf*vKeq;\n" }{TEXT 296 30 "bio_
val:=[1000.,vkf,vkb,vKeq];" }}{PARA 0 "" 0 "" {TEXT 318 0 "" }}{PARA 0
 "" 0 "" {TEXT 318 0 "" }}{EXCHG {PARA 0 "> " 0 "" {MPLTEXT 1 0 13 "np
aram := 6 ;" }}{PARA 11 "" 1 "" {XPPMATH 20 ">I'nparamG6\"\"\"'" }}}
{EXCHG {PARA 0 "> " 0 "" {MPLTEXT 1 0 51 "bio_name := [kA, kB, k_dec, \+
miu_max, yields, f_a] ;" }{MPLTEXT 1 0 1 " " }}{PARA 11 "" 1 "" 
{XPPMATH 20 ">I)bio_nameG6\"7(I#kAGF$I#kBGF$I&k_decGF$I(miu_maxGF$I'yi
eldsGF$I$f_aGF$" }}}{EXCHG {PARA 0 "> " 0 "" {MPLTEXT 1 0 58 "bio_val \+
:= [8.33e-2, 3.13e-2, 1.1574e-6, 1.0e-5, 0.5, 1] ;" }{MPLTEXT 1 0 2 " \+
\n" }}{PARA 11 "" 1 "" {XPPMATH 20 ">I(bio_valG6\"7($\"$L)!\"%$\"$8$F(
$\"&u:\"!#5$\"#5!\"'$\"\"&!\"\"\"\"\"" }}}{SECT 0 {PARA 3 "" 0 "" 
{TEXT 321 8 "Switches" }}{PARA 0 "" 0 "" {TEXT 226 55 "Switches can be
 used in the rate equations. Specify in " }{TEXT 26 9 "nswitches" }
{TEXT 226 114 ", how many switches are in use, name them and define th
e switch expressions. The switch names must also appear in " }{TEXT 
26 8 "bio_name" }{TEXT 226 179 " and must be assigned a dummy value th
ere. The switch equals 1 if the switch expression is >0, 0 otherwise. \+
To reference the coordinates in the domain, use x_pos, y_pos and z_pos
." }}{EXCHG {PARA 0 "> " 0 "" {MPLTEXT 1 0 16 "nswitches := 0 ;" }}
{PARA 11 "" 1 "" {XPPMATH 20 ">I*nswitchesG6\"\"\"!" }}}{EXCHG {PARA 0
 "> " 0 "" {MPLTEXT 1 0 26 "switchlist := [sw1, sw2] ;" }}{PARA 11 "" 
1 "" {XPPMATH 20 ">I+switchlistG6\"7$I$sw1GF$I$sw2GF$" }}}{EXCHG 
{PARA 0 "> " 0 "" {MPLTEXT 1 0 74 "switchcrit := [x(j) - (depthmax/(2.
0*Ncol-Col_size/2.0)), 1.0e-2 - x(j)] ;" }}{PARA 11 "" 1 "" {XPPMATH 
20 ">I+switchcritG6\"7$,&-I\"xGF$6#I\"jGF$\"\"\"*&I)depthmaxGF$F+,&I%N
colGF$$\"#?!\"\"I)Col_sizeGF$$!+++++]!#5F2F2,&$\"#5!\"$F+F'F2" }}}
{PARA 3 "" 0 "" {TEXT 321 0 "" }}}}{SECT 0 {PARA 3 "" 0 "" {TEXT 321 
32 " Transport - Molecular Diffusion" }}{PARA 0 "" 0 "" {TEXT 318 54 "
Specification of the molecular diffusion coefficients\n" }{TEXT 26 9 "
diffdata:" }{TEXT 318 63 " molecular diffusion coefficient at 0 degree
 celsius (cm^2/yr)\n" }{TEXT 26 11 "alphadata: " }{TEXT 318 59 "temper
ature dependence of the diffusion coefficient (1/K) \n" }{TEXT 318 88 
"the in situ molecular diffusion coefficient, corrected for tortuosity
 is calculated as:\n" }{TEXT 318 75 "D(T,sal) = [(0.95-0.001*sal)* D(T
=0,sal=0)*(1 + muc*T[C])]/(1-ln(por^2))  \n" }{TEXT 297 9 "example:\n"
 }{TEXT 298 37 "diffdata := [100., 304.,0.,0.,100.];\n" }{TEXT 299 38 
"alphadata:= [0.006, 0.04,0.,0.,.0.05];" }}{EXCHG {PARA 0 "> " 0 "" 
{MPLTEXT 1 0 39 "diffdata := [0.63e-9,1,1,1, 1, 1, 1] ;\n" }{MPLTEXT 
1 0 33 "alphadata := [0,0,0,0, 0, 0, 0] ;" }{MPLTEXT 1 0 2 " \n" }}
{PARA 11 "" 1 "" {XPPMATH 20 ">I)diffdataG6\"7)$\"#j!#6\"\"\"F)F)F)F)F
)" }}{PARA 11 "" 1 "" {XPPMATH 20 ">I*alphadataG6\"7)\"\"!F&F&F&F&F&F&
" }}}}{SECT 0 {PARA 3 "" 0 "" {TEXT 321 32 " Transport - Boundary Cond
itions" }}{PARA 0 "" 0 "" {TEXT 318 71 "Specification of upper and low
er boundary conditions for each species.\n" }{TEXT 318 21 "There are 3
 options \n" }{TEXT 318 42 "0. known concentration (Dirichlet, M/L^3)
\n" }{TEXT 318 51 "1. known concentration gradient (Neumann, M/L^3*L)
\n" }{TEXT 318 63 "2. known total (diffusive and advective) flux (Robi
n, M/L^2/T)\n" }{TEXT 318 346 "technical note: option 1 and 2 involve \+
ghost points outside the domain. If the mixing parameters vary with de
pth, one needs to assign a mixing intensities at the ghost points. By \+
default this is done by linear extrapolation. To ovrwrite this, the us
er has to edit gridsetup.f and advdiffcoeff.f (both at the bottom; exp
lanations are given there)\n" }{TEXT 26 8 "type_up:" }{TEXT 318 90 " a
rray defining the type of condition for each species at the upper boun
dary (0, 1 or 2) \n" }{TEXT 26 11 "bnddata_up:" }{TEXT 300 1 " " }
