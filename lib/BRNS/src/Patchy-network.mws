{SECT 0 {PARA 3 "" 0 "" {TEXT 321 28 " Biogeochemistry - Rate laws" }}
{PARA 0 "" 0 "" {TEXT 319 14 "Definition of " }{TEXT 278 17 "kinetic r
ate laws" }}{PARA 0 "" 0 "" {TEXT 26 8 "rate.i :" }{TEXT 319 18 " arra
y of rates. \n" }{TEXT 279 76 "- For equilibrium rate expression, a ki
netic rate MUST be specified as well." }{TEXT 319 297 " It will be ove
rwritten in the equilibrium section below, but you need it as space ho
lder and stoichiometry. Furthermore, the steadystate module uses detai
led balancing method with fast kinetics. Therefore, in the example bel
ow, kf will have to be defined as a rather large number and kb = kf*Ke
q\n" }{TEXT 319 70 "note: all other variables are temporary and are NO
T parsed to the ACG\n" }{TEXT 319 2 "- " }{TEXT 280 22 "conditional st
atements" }{TEXT 319 454 ": if a rate law depends on a conditional sta
tement you need to make use of the subroutine switches.f. Example: dis
solution (Rd) is only to take place at undersaturation, thus  Rd= f(sa
turation). If saturation > 1, Rd>0, else Rd=0. This canbe implemented \+
as Rd:=k*H1*saturation, where H1 is toggled between 0 and 1. Rather th
an giving the condition here in maple, for now you need to do this in \+
\"switches.f\", where you program the conditions for H1, e.g. " }{TEXT
 281 31 "H1=0, If (A*B/K>1) then H1 = 1." }{TEXT 319 1 "\n" }{TEXT 
319 2 " \n" }{TEXT 282 10 "example: \n" }{TEXT 283 61 "rate1 := 1000.*
O2*hs; # rate law for 2O2 + HS -> SO4 + Hplus\n" }{TEXT 284 88 "rate2 \+
:= kf*hplus*co3 - kb*hco3; # kinetic rate law for HCO3 = CO3 + Hplus (
equilibrium)" }}{SECT 0 {PARA 4 "" 0 "" {TEXT 323 0 "" }}{EXCHG {PARA 
4 "" 0 "" {TEXT 323 25 " Primary redox reactions " }{HYPERLNK 17 "WWW"
 4 "http://www.geo.uu.nl/Research/Geochemistry/kb/Knowledgebook/Hetero
3.pdf" "" }{TEXT 323 0 "" }{MPLTEXT 1 0 0 "" }}}{PARA 4 "" 0 "" {TEXT 
323 31 " Sulfide Re-oxidation reactions" }}{EXCHG {PARA 0 "> " 0 "" 
{MPLTEXT 1 0 15 "rate1 := miu_H*" }{MPLTEXT 1 0 16 "(C_S/(K_S+C_S))*" 
}{MPLTEXT 1 0 21 "(C_O/(K_OH+C_O))*X_BH" }{MPLTEXT 1 0 2 ";\n" }
{MPLTEXT 1 0 9 "rate2 := " }{MPLTEXT 1 0 4 "k_h*" }{MPLTEXT 1 0 19 "(X
_S/(K_X+X_S))*X_S" }{MPLTEXT 1 0 2 ";\n" }{MPLTEXT 1 0 9 "rate3 := " }
{MPLTEXT 1 0 8 "b_h*X_BH" }{MPLTEXT 1 0 2 ";\n" }{MPLTEXT 1 0 15 "rate
4 := miu_A*" }{MPLTEXT 1 0 19 "(C_NH/(K_NH+C_NH))*" }{MPLTEXT 1 0 16 "
(C_O/(K_OA+C_O))" }{MPLTEXT 1 0 7 "*X_BA;\n" }{MPLTEXT 1 0 19 "rate5 :
= b_A*X_BA;\n" }{MPLTEXT 1 0 20 "rate6 := nu_g*miu_H*" }{MPLTEXT 1 0 
15 "(C_S/(K_S+C_S))" }{MPLTEXT 1 0 1 "*" }{MPLTEXT 1 0 18 "(C_NO/(K_NO
+C_NO))" }{MPLTEXT 1 0 1 "*" }{MPLTEXT 1 0 17 "(K_OH/(K_OH+C_O))" }
{MPLTEXT 1 0 6 "*X_BH;" }}{PARA 11 "" 1 "" {XPPMATH 20 ">I&rate1G6\"*.
I&miu_HGF$\"\"\"I$C_SGF$F',&I$K_SGF$F'F(F'!\"\"I$C_OGF$F',&I%K_OHGF$F'
F,F'F+I%X_BHGF$F'" }}{PARA 11 "" 1 "" {XPPMATH 20 ">I&rate2G6\"*(I$k_h
GF$\"\"\"I$X_SGF$\"\"#,&I$K_XGF$F'F(F'!\"\"" }}{PARA 11 "" 1 "" 
