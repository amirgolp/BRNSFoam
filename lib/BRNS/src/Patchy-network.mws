{PARA 3 "" 0 "" {TEXT 321 32 " Transport - Boundary Conditions" }}
{PARA 0 "" 0 "" {TEXT 319 71 "Specification of upper and lower boundar
y conditions for each species.\n" }{TEXT 319 21 "There are 3 options \+
\n" }{TEXT 319 42 "0. known concentration (Dirichlet, M/L^3)\n" }{TEXT
 319 51 "1. known concentration gradient (Neumann, M/L^3*L)\n" }{TEXT 
319 63 "2. known total (diffusive and advective) flux (Robin, M/L^2/T)
\n" }{TEXT 319 346 "technical note: option 1 and 2 involve ghost point
s outside the domain. If the mixing parameters vary with depth, one ne
eds to assign a mixing intensities at the ghost points. By default thi
s is done by linear extrapolation. To ovrwrite this, the user has to e
dit gridsetup.f and advdiffcoeff.f (both at the bottom; explanations a
re given there)\n" }{TEXT 26 8 "type_up:" }{TEXT 319 90 " array defini
ng the type of condition for each species at the upper boundary (0, 1 \+
or 2) \n" }{TEXT 26 11 "bnddata_up:" }{TEXT 302 1 " " }{TEXT 319 60 "a
rray containing the values specified at the upper boundary." }}{PARA 0
 "" 0 "" {TEXT 26 10 "type_down:" }{TEXT 319 77 " array defining the t
ype of condition for each species at the lower boundary " }}{PARA 0 ""
 0 "" {TEXT 26 13 "bnddata_down:" }{TEXT 303 1 " " }{TEXT 319 60 "arra
y containing the values specified at the upper boundary." }}{PARA 214 
"" 0 "" {TEXT 26 0 "" }{TEXT 304 1 "\n" }{TEXT 305 9 "example:\n" }
{TEXT 306 20 "type_up := [0,0,2];\n" }{TEXT 307 33 "bnddata_up := [1.4
,0.001,0.001];\n" }{TEXT 308 21 "type_down := [1,1,1];" }}{PARA 0 "" 0
 "" {TEXT 226 27 "bnddata_down := [0.,0.,0.];" }{TEXT 309 0 "" }{TEXT 
226 0 "" }}{EXCHG {PARA 0 "> " 0 "" {MPLTEXT 1 0 25 "type_up := [1,1,1
,1,1,1,1" }{MPLTEXT 1 0 4 "] ;\n" }{MPLTEXT 1 0 28 "bnddata_up := [1,1
,1,1,1,1,1" }{MPLTEXT 1 0 5 "] ; \n" }{MPLTEXT 1 0 27 "type_down := [0
,0,0,0,0,0,0" }{MPLTEXT 1 0 4 "] ;\n" }{MPLTEXT 1 0 30 "bnddata_down :
= [0,0,0,0,0,0,0" }{MPLTEXT 1 0 3 "] ;" }{MPLTEXT 1 0 0 "" }}{PARA 11 
