3 "" 0 "" {TEXT 321 29 " Biogeochemistry - Parameters" }}{PARA 0 "" 0 
"" {TEXT 32 41 "Values of rates constants and parameters " }{TEXT 319 
1 "\n" }{TEXT 319 82 "In this section, all parameters defined in secti
on 'Rate laws' should be defined.\n" }{TEXT 26 6 "nparam" }{TEXT 319 
34 ": number of parameters to define \n" }{TEXT 319 21 "The list is gi
ven by " }{TEXT 26 8 "bio_name" }{TEXT 319 26 "; the values collected \+
in " }{TEXT 26 8 "bio_val." }{TEXT 319 1 "\n" }{TEXT 319 60 "note that
 for double precision, 10 should be written as 10.\n" }{TEXT 319 1 "\n
" }{TEXT 292 9 "example:\n" }{TEXT 293 11 "nparam:=4;\n" }{TEXT 294 
30 "bio_name:=[kmo2hs,kf,kb,Keq];\n" }{TEXT 295 18 "vkf :=1.0*10^(5);
\n" }{TEXT 296 22 "vKeq:=1.0*10^(-10.4);\n" }{TEXT 297 16 "vkb :=vkf*v
Keq;\n" }{TEXT 298 30 "bio_val:=[1000.,vkf,vkb,vKeq];" }}{PARA 0 "" 0 
