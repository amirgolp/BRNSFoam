{PARA 3 "" 0 "" {TEXT 321 29 " Biogeochemistry - Equilibria" }}{PARA 0
 "" 0 "" {TEXT 319 41 "Specification of equilibrium constraints\n" }
{TEXT 26 10 "eqrxnsId :" }{TEXT 319 75 " set of kinetic reactions whic
h are overuled by a thermodynamic constraint " }}{PARA 0 "" 0 "" {TEXT
 26 20 "equilibriumseqns[i] " }{TEXT 319 42 ": Equilibrium constraint \+
for reaction i  \n" }{TEXT 319 1 "\n" }{TEXT 288 9 "example:\n" }{TEXT
 289 20 "eqrxnID := [r2,rX];\n" }{TEXT 290 44 "equilibriumeqns[1] := h
plus*co3 - Keq*hco3;\n" }{TEXT 291 26 "equilibriumeqns[2] := ...;" }}
{EXCHG {PARA 0 "> " 0 "" {MPLTEXT 1 0 15 "eqrxnId := [] ;" }}{PARA 11 
