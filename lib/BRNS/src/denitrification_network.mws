{TEXT 319 18 " List of variables" }}{PARA 0 "" 0 "" {TEXT 26 10 "varia
bles:" }{TEXT 318 39 " list of variables to model. example: \n" }{TEXT
 26 11 "listsolids:" }{TEXT 318 43 " species number which is a SOLID s
pecies. \n" }{TEXT 318 70 "note: all other variables are temporary and
 are NOT parsed to the ACG\n" }{TEXT 318 1 "\n" }{TEXT 274 10 "Example
: \n" }{TEXT 275 56 "variables:=[O2, so4, MnOx, FeOx, hco3, co3, hplus
, hs];\n" }{TEXT 276 20 "listsolids: = [3,4];" }}{EXCHG {PARA 0 "> " 0
 "" {MPLTEXT 1 0 1 " " }{MPLTEXT 1 0 62 "variables := [C_substrate, C_
N2O, C_NO, C_NO2, C_NO3, C_O2, C_" }{MPLTEXT 1 0 5 "bio, " }{MPLTEXT 
1 0 19 "C_NaP, C_NiR, C_NoR" }{MPLTEXT 1 0 4 "] ;\n" }{MPLTEXT 1 0 18 
"listsolids := [] ;" }}{PARA 11 "" 1 "" {XPPMATH 20 ">I*variablesG6\"7
,I,C_substrateGF$I&C_N2OGF$I%C_NOGF$I&C_NO2GF$I&C_NO3GF$I%C_O2GF$I&C_b
ioGF$I&C_NaPGF$I&C_NiRGF$I&C_NoRGF$" }}{PARA 11 "" 1 "" {XPPMATH 20 ">
I+listsolidsG6\"7\"" }}}}}{SECT 0 {PARA 3 "" 0 "" {TEXT 320 28 " Bioge
ochemistry - Rate laws" }}{PARA 0 "" 0 "" {TEXT 318 14 "Definition of 
" }{TEXT 277 17 "kinetic rate laws" }}{PARA 0 "" 0 "" {TEXT 26 8 "rate
.i :" }{TEXT 318 18 " array of rates. \n" }{TEXT 278 76 "- For equilib
rium rate expression, a kinetic rate MUST be specified as well." }
{TEXT 318 297 " It will be overwritten in the equilibrium section belo
w, but you need it as space holder and stoichiometry. Furthermore, the
 steadystate module uses detailed balancing method with fast kinetics.
 Therefore, in the example below, kf will have to be defined as a rath
er large number and kb = kf*Keq\n" }{TEXT 318 70 "note: all other vari
ables are temporary and are NOT parsed to the ACG\n" }{TEXT 318 2 "- "
 }{TEXT 279 22 "conditional statements" }{TEXT 318 454 ": if a rate la
w depends on a conditional statement you need to make use of the subro
utine switches.f. Example: dissolution (Rd) is only to take place at u
ndersaturation, thus  Rd= f(saturation). If saturation > 1, Rd>0, else
 Rd=0. This canbe implemented as Rd:=k*H1*saturation, where H1 is togg
led between 0 and 1. Rather than giving the condition here in maple, f
or now you need to do this in \"switches.f\", where you program the co
nditions for H1, e.g. " }{TEXT 280 31 "H1=0, If (A*B/K>1) then H1 = 1.
" }{TEXT 318 1 "\n" }{TEXT 318 2 " \n" }{TEXT 281 10 "example: \n" }
{TEXT 282 61 "rate1 := 1000.*O2*hs; # rate law for 2O2 + HS -> SO4 + H
plus\n" }{TEXT 283 88 "rate2 := kf*hplus*co3 - kb*hco3; # kinetic rate
 law for HCO3 = CO3 + Hplus (equilibrium)" }}{SECT 0 {PARA 4 "" 0 "" 
{TEXT 322 0 "" }}{EXCHG {PARA 4 "" 0 "" {TEXT 322 25 " Primary redox r
eactions " }{HYPERLNK 17 "WWW" 4 "http://www.geo.uu.nl/Research/Geoche
mistry/kb/Knowledgebook/Hetero3.pdf" "" }{TEXT 322 0 "" }{MPLTEXT 1 0 
0 "" }}}{PARA 4 "" 0 "" {TEXT 322 31 " Sulfide Re-oxidation reactions"
 }}{EXCHG {PARA 0 "> " 0 "" {MPLTEXT 1 0 59 "rate1 := miuMax*C_bio*(C_
O2/(K_O2*(1+C_NO/K_NO_O2)+C_O2));\n" }{MPLTEXT 1 0 9 "rate2 := " }
{MPLTEXT 1 0 6 "miuMax" }{MPLTEXT 1 0 1 "*" }{MPLTEXT 1 0 5 "C_bio" }
{MPLTEXT 1 0 55 "*C_NaP*(C_NO3/(K_NO3+C_NO3))*(K_O2_NaP/(K_O2_NaP+C_O2
))" }{MPLTEXT 1 0 2 ";\n" }{MPLTEXT 1 0 9 "rate3 := " }{MPLTEXT 1 0 6 
"miuMax" }{MPLTEXT 1 0 1 "*" }{MPLTEXT 1 0 5 "C_bio" }{MPLTEXT 1 0 1 "
*" }{MPLTEXT 1 0 6 "C_NiR*" }{MPLTEXT 1 0 13 "(C_NO2/(K_NO2" }{MPLTEXT
 1 0 35 "+C_NO2))*(K_O2_NiR/(K_O2_NiR+C_O2))" }{MPLTEXT 1 0 2 ";\n" }
{MPLTEXT 1 0 15 "rate4 := miuMax" }{MPLTEXT 1 0 1 "*" }{MPLTEXT 1 0 5 
"C_bio" }{MPLTEXT 1 0 40 "*C_NoR*(C_NO/(K_NO+(1+C_NO/K_NO)*C_O2))*" }
{MPLTEXT 1 0 45 "(C_NO/(K_NO+(1+C_NO/K_NO)*C_O2))*(K_O2_NoR/(K" }
{MPLTEXT 1 0 12 "_O2_NoR+C_O2" }{MPLTEXT 1 0 2 "))" }{MPLTEXT 1 0 2 ";
\n" }{MPLTEXT 1 0 82 "rate5 := nu_NaP*(C_NO3/(K_NO3_NaP + C_NO3))*(K_O
2_NaP/(K_O2_NaP+C_O2))*(1-C_NaP);\n" }{MPLTEXT 1 0 55 "rate6 := nu_NiR
*(C_NO2/(K_NO2_NiR + C_NO2))*(1-C_NiR);\n" }{MPLTEXT 1 0 17 "rate7 := \+
nu_NoR*(" }{MPLTEXT 1 0 34 "C_NO/(K_NO_NoR + C_NO))*(1-C_NoR);" }}
{PARA 11 "" 1 "" {XPPMATH 20 ">I&rate1G6\"**I'miuMaxGF$\"\"\"I&C_bioGF
$F'I%C_O2GF$F',&*&I%K_O2GF$F',&F'F'*&I%C_NOGF$F'I(K_NO_O2GF$!\"\"F'F'F
'F)F'F1" }}{PARA 11 "" 1 "" {XPPMATH 20 ">I&rate2G6\"*0I'miuMaxGF$\"\"
\"I&C_bioGF$F'I&C_NaPGF$F'I&C_NO3GF$F',&I&K_NO3GF$F'F*F'!\"\"I)K_O2_Na
PGF$F',&F.F'I%C_O2GF$F'F-" }}{PARA 11 "" 1 "" {XPPMATH 20 ">I&rate3G6
\"*0I'miuMaxGF$\"\"\"I&C_bioGF$F'I&C_NiRGF$F'I&C_NO2GF$F',&I&K_NO2GF$F
'F*F'!\"\"I)K_O2_NiRGF$F',&F.F'I%C_O2GF$F'F-" }}{PARA 11 "" 1 "" 
{XPPMATH 20 ">I&rate4G6\"*0I'miuMaxGF$\"\"\"I&C_bioGF$F'I&C_NoRGF$F'I%
C_NOGF$\"\"#,&I%K_NOGF$F'*&,&F'F'*&F*F'F-!\"\"F'F'I%C_O2GF$F'F'!\"#I)K
_O2_NoRGF$F',&F4F'F2F'F1" }}{PARA 11 "" 1 "" {XPPMATH 20 ">I&rate5G6\"
*.I'nu_NaPGF$\"\"\"I&C_NO3GF$F',&I*K_NO3_NaPGF$F'F(F'!\"\"I)K_O2_NaPGF
$F',&F,F'I%C_O2GF$F'F+,&F'F'I&C_NaPGF$F+F'" }}{PARA 11 "" 1 "" 
{XPPMATH 20 ">I&rate6G6\"**I'nu_NiRGF$\"\"\"I&C_NO2GF$F',&I*K_NO2_NiRG
F$F'F(F'!\"\",&F'F'I&C_NiRGF$F+F'" }}{PARA 11 "" 1 "" {XPPMATH 20 ">I&
rate7G6\"**I'nu_NoRGF$\"\"\"I%C_NOGF$F',&I)K_NO_NoRGF$F'F(F'!\"\",&F'F
'I&C_NoRGF$F+F'" }}}}}{SECT 0 {PARA 3 "" 0 "" {TEXT 320 33 " Biogeoche
mistry - Stoichiometry\n" }}{PARA 0 "" 0 "" {TEXT 318 46 "Stoichiometr
y of the biogeochemical reactions\n" }{TEXT 26 9 "d.sp.dt :" }{TEXT 
318 66 " rates of change of sp due to the sum of biogeochemical reacti
ons\n" }{TEXT 318 44 "note that rateX must be referred to as rX  \n" }
{TEXT 318 2 " \n" }{TEXT 284 9 "example:\n" }{TEXT 285 16 "dO2dt := -2
*r1;\n" }{TEXT 286 14 "dhco3dt = -r2;" }{TEXT 318 1 " " }}{EXCHG 
{PARA 0 "> " 0 "" {MPLTEXT 1 0 22 "delstd := 0.0112372 ;\n" }{MPLTEXT 
1 0 16 "s_dens := 2.5 ;\n" }{MPLTEXT 1 0 48 "#SD := 1.0e3 * s_dens * (
1.0 - por(j)) / por(j);" }{MPLTEXT 1 0 0 "" }}{PARA 11 "" 1 "" 
{XPPMATH 20 ">I'delstdG6\"$\"'sB6!\"(" }}{PARA 11 "" 1 "" {XPPMATH 20 
">I's_densG6\"$\"#D!\"\"" }}}{PARA 0 "" 0 "" {TEXT 318 0 "" }}{EXCHG 
{PARA 0 "> " 0 "" {MPLTEXT 1 0 1 "d" }{MPLTEXT 1 0 5 "C_bio" }{MPLTEXT
 1 0 33 "dt := 2.2*r1 + 1.8*(r2 + r3 + r4)" }{MPLTEXT 1 0 3 " ;\n" }
{MPLTEXT 1 0 18 "dC_substratedt := " }{MPLTEXT 1 0 20 "-(r1 + r2 + r3 \+
+ r4)" }{MPLTEXT 1 0 3 " ;\n" }{MPLTEXT 1 0 23 "dC_NO3dt := -3.23*r2 ;
\n" }{MPLTEXT 1 0 1 "d" }{MPLTEXT 1 0 5 "C_NO2" }{MPLTEXT 1 0 23 "dt :
= 3.23*r2 - 6.45*r3" }{MPLTEXT 1 0 3 " ;\n" }{MPLTEXT 1 0 1 "d" }
{MPLTEXT 1 0 4 "C_NO" }{MPLTEXT 1 0 26 "dt := 6.45*r3 - 6.45*r4 ;\n" }
{MPLTEXT 1 0 1 "d" }{MPLTEXT 1 0 5 "C_N2O" }{MPLTEXT 1 0 16 "dt := 3.2
3*r4 ;\n" }{MPLTEXT 1 0 1 "d" }{MPLTEXT 1 0 4 "C_O2" }{MPLTEXT 1 0 16 
"dt := -1.2*r1 ;\n" }{MPLTEXT 1 0 17 "dC_NaPdt := r5 ;\n" }{MPLTEXT 1 
0 17 "dC_NiRdt := r6 ;\n" }{MPLTEXT 1 0 16 "dC_NoRdt := r7 ;" }}{PARA 
11 "" 1 "" {XPPMATH 20 ">I)dC_biodtG6\",*I#r1GF$$\"#A!\"\"I#r2GF$$\"#=
F)I#r3GF$F+I#r4GF$F+" }}{PARA 11 "" 1 "" {XPPMATH 20 ">I/dC_substrated
tG6\",*I#r1GF$!\"\"I#r2GF$F'I#r3GF$F'I#r4GF$F'" }}{PARA 11 "" 1 "" 
{XPPMATH 20 ">I)dC_NO3dtG6\",$I#r2GF$$!$B$!\"#" }}{PARA 11 "" 1 "" 
