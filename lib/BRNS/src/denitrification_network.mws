$!$X'F)" }}{PARA 11 "" 1 "" {XPPMATH 20 ">I)dC_N2OdtG6\",$I#r4GF$$\"$B
$!\"#" }}{PARA 11 "" 1 "" {XPPMATH 20 ">I(dC_O2dtG6\",$I#r1GF$$!#7!\"
\"" }}{PARA 11 "" 1 "" {XPPMATH 20 ">I)dC_NaPdtG6\"I#r5GF$" }}{PARA 11
 "" 1 "" {XPPMATH 20 ">I)dC_NiRdtG6\"I#r6GF$" }}{PARA 11 "" 1 "" 
{XPPMATH 20 ">I)dC_NoRdtG6\"I#r7GF$" }}}}{SECT 0 {PARA 3 "" 0 "" {TEXT
 320 29 " Biogeochemistry - Equilibria" }}{PARA 0 "" 0 "" {TEXT 318 
41 "Specification of equilibrium constraints\n" }{TEXT 26 10 "eqrxnsId
 :" }{TEXT 318 75 " set of kinetic reactions which are overuled by a t
hermodynamic constraint " }}{PARA 0 "" 0 "" {TEXT 26 20 "equilibriumse
qns[i] " }{TEXT 318 42 ": Equilibrium constraint for reaction i  \n" }
{TEXT 318 1 "\n" }{TEXT 287 9 "example:\n" }{TEXT 288 20 "eqrxnID := [
r2,rX];\n" }{TEXT 289 44 "equilibriumeqns[1] := hplus*co3 - Keq*hco3;
\n" }{TEXT 290 26 "equilibriumeqns[2] := ...;" }}{EXCHG {PARA 0 "> " 0
 "" {MPLTEXT 1 0 15 "eqrxnId := [] ;" }}{PARA 11 "" 1 "" {XPPMATH 20 "
>I(eqrxnIdG6\"7\"" }}}{EXCHG {PARA 0 "> " 0 "" {MPLTEXT 1 0 33 "#equil
ibriumeqns[1] := b - k3*c ;" }}}}{SECT 0 {PARA 3 "" 0 "" {TEXT 320 29 
" Biogeochemistry - Parameters" }}{PARA 0 "" 0 "" {TEXT 32 41 "Values \+
of rates constants and parameters " }{TEXT 318 1 "\n" }{TEXT 318 82 "I
n this section, all parameters defined in section 'Rate laws' should b
e defined.\n" }{TEXT 26 6 "nparam" }{TEXT 318 34 ": number of paramete
rs to define \n" }{TEXT 318 21 "The list is given by " }{TEXT 26 8 "bi
o_name" }{TEXT 318 26 "; the values collected in " }{TEXT 26 8 "bio_va
l." }{TEXT 318 1 "\n" }{TEXT 318 60 "note that for double precision, 1
0 should be written as 10.\n" }{TEXT 318 1 "\n" }{TEXT 291 9 "example:
\n" }{TEXT 292 11 "nparam:=4;\n" }{TEXT 293 30 "bio_name:=[kmo2hs,kf,k
b,Keq];\n" }{TEXT 294 18 "vkf :=1.0*10^(5);\n" }{TEXT 295 22 "vKeq:=1.
0*10^(-10.4);\n" }{TEXT 296 16 "vkb :=vkf*vKeq;\n" }{TEXT 297 30 "bio_
val:=[1000.,vkf,vkb,vKeq];" }}{PARA 0 "" 0 "" {TEXT 318 0 "" }}{PARA 0
 "" 0 "" {TEXT 318 0 "" }}{EXCHG {PARA 0 "> " 0 "" {MPLTEXT 1 0 14 "np
aram := 15 ;" }}{PARA 11 "" 1 "" {XPPMATH 20 ">I'nparamG6\"\"#:" }}}
{EXCHG {PARA 0 "> " 0 "" {MPLTEXT 1 0 13 "bio_name := [" }{MPLTEXT 1 
0 8 "miuMax, " }{MPLTEXT 1 0 6 "K_O2, " }{MPLTEXT 1 0 9 "K_NO_O2, " }
{MPLTEXT 1 0 5 "K_NO3" }{MPLTEXT 1 0 9 ", K_NO2, " }{MPLTEXT 1 0 10 "K
_O2_NiR, " }{MPLTEXT 1 0 6 "K_NO, " }{MPLTEXT 1 0 8 "K_O2_NoR" }
